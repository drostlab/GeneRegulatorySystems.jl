{
    "typical_gene" : {
        "base_rates": {
            "activation": 0.05,
            "deactivation": 10.0,
            "trigger": 0.33,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 0.0000009,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 0.000000136
        }
    },
    "branch": true,
    "step": [
        {
            "anchor": {"$": "channel"},
            "t": 100.0,
            "each": ["SortingDirect", "RSSACR"],
            "as": "method",
            "step": {
                "do": {
                    "{regulation/vanilla}": {
                        "method": {"$": "method"},
                        "polymerases": 50,
                        "ribosomes": 5537,
                        "proteasomes": 2215,
                        "genes": [
                            {"$": "typical_gene", "name": "Gene 1"},
                            {
                                "$": "typical_gene",
                                "name": "Gene 2",
                                "repression": [{"from": "Gene 1", "at": 5.0}]
                            }
                        ]
                    }
                },
                "each": {"start": 150, "step": 50, "stop": 200},
                "as": "proteins",
                "step": {
                    "label": "${method}-p${proteins}",
                    "channel": "${anchor}",
                    "branch": true,
                    "each": {"length": 2},
                    "step": [
                        {"{set}": {
                            "Gene 1": {"proteins": {"$": "proteins"}},
                            "Gene 2": {"proteins": {"$": "proteins"}}
                        }},
                        {"$": "t"},
                        {"{extract-transcriptome-amplified}": {
                            "cycles": 3,
                            "target": 200
                        }}
                    ]
                }
            }
        },
        {
            "to": 100.0,
            "step": {"{regulation/kronecker}": {
                "seed": "kronecker-$seed",
                "polymerases": 50,
                "ribosomes": 5537,
                "proteasomes": 2215,
                "base_rates": {"$": ["typical_gene", "base_rates"]},
                "activation": {
                    "adjacency": [
                        [
                            [0.7, 0.6],
                            [0.4, 0.2]
                        ],
                        [
                            [0.7, 0.6],
                            [0.4, 0.2]
                        ]
                    ],
                    "at": ["LogNormal", -5.0, 2.0]
                },
                "repression": {
                    "adjacency": {
                        "initiator": [
                            [0.7, 0.6],
                            [0.5, 0.2]
                        ],
                        "power": 2
                    },
                    "at": ["LogNormal", -5.0, 2.0]
                },
                "proteolysis": {
                    "adjacency": {
                        "initiator": [
                            [0.7, 0.6],
                            [0.5, 0.2]
                        ],
                        "power": 2,
                        "expected_links_per_gene": 0.5
                    },
                    "k": ["LogNormal", -5.0, 2.0]
                }
            }}
        }
    ]

}
