{
    "each": [
        {"kind": "vanilla", "method": "default"},
        {"kind": "vanilla-simple", "method": "default"},
        {"kind": "vanilla-Catalyst", "method": "Direct"},
        {"kind": "vanilla-Catalyst", "method": "SortingDirect"},
        {"kind": "vanilla-Catalyst", "method": "RSSACR"}
    ],
    "as": "variant",
    "in": {
        "model": {
            "kind": {"$": ["variant", "kind"]},
            "method": {"$": ["variant", "method"]},
            "volume": 3000.0,
            "polymerases": 50,
            "ribosomes": 5537,
            "proteasomes": 2215,
            "genes": [
                {
                    "name": "Gene 1",
                    "base_rates": {
                        "activation": 0.05,
                        "deactivation": 10.0,
                        "trigger": 0.33,
                        "transcription": 0.001,
                        "splicing": 1.0,
                        "translation": 0.0000009,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 0.000000136
                    }
                },
                {
                    "name": "Gene 2",
                    "base_rates": {
                        "activation": 0.05,
                        "deactivation": 10.0,
                        "trigger": 0.33,
                        "transcription": 0.001,
                        "splicing": 1.0,
                        "translation": 0.0000009,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 0.000000136
                    },
                    "repression": [{"from": "Gene 1", "at": 0.00277}]
                }
            ]
        },
        "each": {"start": 150, "step": 10, "stop": 160},
        "as": "proteins",
        "in": {
            "initial": {
                "Gene 1": {"proteins": {"$": "proteins"}},
                "Gene 2": {"proteins": {"$": "proteins"}}
            },
            "kind": {"$": ["variant", "kind"]},
            "method": {"$": ["variant", "method"]},
            "each": [100.0, 200.0],
            "as": "t",
            "in": [
                {
                    "take": {"$": "t"},
                    "label": "$kind-$method-initial-$proteins-at$t",
                    "each": {"length": 2}
                },
                {
                    "take": {"to": {"$": "t"}},
                    "label": "$kind-$method-initial-$proteins-to$t"
                }
            ]
        }
    }
}
