{
    "label": "repressilator-entrained",
    "repressilator": {
        "genes": [
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_1", "at": 2.0}],
                "repression": [{"from": "gene_3", "at": 4.0}],
                "name": "gene_1"
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_2", "at": 2.0}],
                "repression": [{"from": "gene_1", "at": 4.0}],
                "name": "gene_2"
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_3", "at": 2.0}],
                "repression": [{"from": "gene_2", "at": 4.0}],
                "name": "gene_3"
            }
        ]
    },
    "step": {
        "dark_model": {"{regulation/v1}": {"$": "repressilator"}},
        "light_model": {"{regulation/v1}": {
            "$": "repressilator",
            "reactions": [{"from": ["gene_2"], "rate": 0.001, "to": []}]
        }},
        "step": [
            {"{seed}": "${seed}-rep"},
            {"{add}": {
                "$": ["defaults", "bootstrap"],
                "gene_1.proteins": 100
            }},
            {"to": 105000.0, "step": [
                {"to": 30000.0, "do": {"$": "dark_model"}},
                {"to": 5000.0, "step": 10.0, "do": {"$": "light_model"}}
            ]},
            {
                "branch": true,
                "each": {"length": 3},
                "step": {"to": 105000.0, "step": [
                    {"to": 30000.0, "step": 10.0, "do": {"$": "dark_model"}},
                    {"to": 5000.0, "step": 10.0, "do": {"$": "light_model"}}
                ]}
            }
        ]
    }
}
