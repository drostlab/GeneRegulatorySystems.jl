{
    "anchor": "${channel}",
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "$": ["defaults", "gene"],
                    "activation": [{"from": 1, "at": 20.0}],
                    "repression": [{"from": 2, "at": 20.0}]
                },
                {
                    "$": ["defaults", "gene"],
                    "activation": [{"from": 2, "at": 2.0}],
                    "repression": [{"from": 1, "at": 20.0}]
                }
            ]
        }},
        "each": {"start": 2500, "step": 2500, "stop": 5000},
        "as": "a",
        "step": {
            "each": {"start": 2500, "step": 2500, "stop": 5000},
            "as": "b",
            "step": {
                "label": "switch-${a}-${b}",
                "branch": true,
                "each": {"length": 1},
                "step": {
                    "channel": "${anchor}",
                    "step": [
                        {"{add}": {
                            "$": ["defaults", "bootstrap"],
                            "1.proteins": {"$": "a"},
                            "2.proteins": {"$": "b"}
                        }},
                        {"to": 25000.0}
                    ]
                }
            }
        }
    }
}
