{
    "label": "acdc-simpler",
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "$": ["defaults", "gene"],
                    "activation": [{"from": 1, "at": 0.01}],
                    "repression": [{"from": 3, "at": 4.0}]
                },
                {
                    "$": ["defaults", "gene"],
                    "activation": [{"from": 2, "at": 1.0}],
                    "repression": [{"from": 1, "at": 0.004}]
                },
                {
                    "$": ["defaults", "gene"],
                    "activation": [{"from": 3, "at": 2.0}],
                    "activation": [{"from": 2, "at": 4.0}, {"from": 1, "at": 4.0}]
                }
            ]
        }},
        "step": [
            {"{seed}": "${seed}-rep"},
            {"{add}": {
                "$": ["defaults", "bootstrap"],
                "2.proteins": 100
            }},
            {"to": 45500.0, "step": 100.0},
            {
                "branch": true,
                "each": {"length": 5},
                "as": "i",
                "step": [
                    {"{seed}": "${seed}-repress-${i}"},
                    {"to": 45500.0}
                ]
            }
        ]
    }
}
