{
    "model": {
        "kind": "VanillaModel",
        "volume": 3000.0,
        "genes": ["Gene 1", "Gene 2"],
        "polymerases": 50.0,
        "ribosomes": 5537.0,
        "proteasomes": 2215.0,
        "links": [
            {"from": "Gene 1", "to": "Gene 2", "k": -1, "repression": 0.00277, "activation": "Inf"}
        ],
        "aggregations": ["minimum", "minimum"],
        "rates": {
            "activation": [0.05, 0.05],
            "deactivation": [10.0, 10.0],
            "trigger": [0.33, 0.33],
            "transcription": [0.001, 0.001],
            "splicing": [1.0, 1.0],
            "translation": [0.0000009, 0.0000009],
            "abortion": [0.01, 0.01],
            "premrna_decay": [0.01, 0.01],
            "mrna_decay": [0.001, 0.001],
            "protein_decay": [0.000000136, 0.000000136]
        }
    },
    "each": {"start": 50, "step": 10, "stop": 200},
    "as": "proteins",
    "in": {
        "initial": {
            "proteins": [{"$": "proteins"}, {"$": "proteins"}]
        },
        "each": [200.0, 1000.0, 5000.0],
        "as": "t",
        "in": {
            "take": {"$": "t"},
            "label": "initial-$proteins-t$t",
            "each": {"start": 1, "length": 5}
        }
    }
}
