{
    "genes": ["G1", "G2"],
    "each": [1000.0, 3000.0, 10000.0],
    "as": "volume",
    "in": {
        "channel": "$^genes",
        "model": {
            "kind": "VanillaModel",
            "volume": {"$": "volume"},
            "genes": {"$": "genes"},
            "polymerases": 50.0,
            "ribosomes": 5537.0,
            "proteasomes": 2215.0,
            "links": [
                {"from": "G1", "to": "G2", "k": -1, "repression": 0.00277, "activation": "Inf"}
            ],
            "rates": {
                "activation": [0.05, 0.05],
                "deactivation": [10.0, 10.0],
                "trigger": [0.33, 0.33],
                "transcription": [0.001, 0.001],
                "splicing": [1.0, 1.0],
                "translation": [0.0000009, 0.0000009],
                "abortion": [0.01, 0.01],
                "premrna_decay": [0.01, 0.01],
                "mrna_decay": [0.001, 0.001],
                "protein_decay": [0.000000136, 0.000000136]
            }
        },
        "initial": {"proteins": [100, 200]},
        "take": {"to": 1000.0},
        "each": {"start": 1, "length": 3}
    }
}
