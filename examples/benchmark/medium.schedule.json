{
    "into": "${channel}",
    "each": {"start": 8, "stop": 9},
    "as": "k",
    "step": [
        {"{set}": {"polymerases": 500000}},
        {
            "into": "${into}-k${k}",
            "label": "benchmark-SKG-k${k}",
            "branch": true,
            "each": {"length": 3},
            "as": "replicate",
            "step": {
                "to": 50000.0,
                "step": 100.0,
                "do": {"{regulation/kronecker}": {
                    "seed": "${seed}-${label}-${replicate}",
                    "ribosomes": 5537,
                    "proteasomes": 2215,
                    "base_rates": {
                        "activation": 2.5,
                        "deactivation": 10.0,
                        "trigger": 0.00000066,
                        "transcription": 0.001,
                        "splicing": 1.0,
                        "translation": 0.0000009,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 0.000000136
                    },
                    "activation": {
                        "adjacency": {
                            "initiator": [
                                [0.8, 0.6],
                                [0.4, 0.2]
                            ],
                            "power": {"$": "k"},
                            "expected_links_per_gene": 0.8
                        },
                        "at": ["LogNormal", -5.0, 2.0]
                    },
                    "repression": {
                        "adjacency": {
                            "initiator": [
                                [0.6, 0.5],
                                [0.4, 0.2]
                            ],
                            "power": {"$": "k"},
                            "expected_links_per_gene": 0.7
                        },
                        "at": ["LogNormal", -5.0, 2.0]
                    },
                    "proteolysis": {
                        "adjacency": {
                            "initiator": [
                                [0.4, 0.3],
                                [0.2, 0.1]
                            ],
                            "power": {"$": "k"},
                            "expected_links_per_gene": 0.5
                        },
                        "k": ["LogNormal", -5.0, 2.0]
                    }
                }}
            }
        }
    ]
}
