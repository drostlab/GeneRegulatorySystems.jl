{
    "into": "${channel}",
    "each": {"start": 2, "stop": 4},
    "as": "k",
    "step": [
        {"{add}": {
            "polymerases": 5e5,
            "ribosomes": 2e6,
            "proteasomes": 1e6
        }},
        {
            "into": "${into}-k${k}",
            "label": "benchmark-SKG-k${k}",
            "branch": true,
            "each": {"length": 10},
            "as": "replicate",
            "step": {
                "to": 25000.0,
                "step": {"to": 5000.0},
                "do": {"{regulation/kronecker}": {
                    "seed": "${seed}-${label}-${replicate}",
                    "base_rates": {
                        "activation": 2.5,
                        "deactivation": 10.0,
                        "trigger": 6.6e-7,
                        "transcription": 0.001,
                        "splicing": 0.02,
                        "translation": 2.5e-9,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 3e-10
                    },
                    "activation": {
                        "adjacency": {
                            "initiator": [
                                [0.8, 0.6],
                                [0.4, 0.2]
                            ],
                            "power": {"$": "k"},
                            "expected_links_per_gene": 0.8
                        },
                        "at": ["LogNormal", 2.0, 1.0]
                    },
                    "repression": {
                        "adjacency": {
                            "initiator": [
                                [0.6, 0.5],
                                [0.4, 0.2]
                            ],
                            "power": {"$": "k"},
                            "expected_links_per_gene": 0.7
                        },
                        "at": ["LogNormal", 2.0, 1.0]
                    }
                }}
            }
        }
    ]
}
