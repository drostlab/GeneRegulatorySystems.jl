{
    "label": "2-repressilators",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 0.00000066,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 0.0000009,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 0.000000136
        }
    },
    "step": {
        "branch": true,
        "each": {"length": 5},
        "step": [
            {"{set}": {
                "polymerases": 500000,
                "P1.proteins": 100,
                "P2.proteins": 100,
                "P3.proteins": 100,
                "S1.proteins": 100,
                "S2.proteins": 100,
                "S3.proteins": 100
            }},
            {"to": 1000000.0, "step": 10000.0}
        ],
        "do": {"{regulation/vanilla}": {
            "ribosomes": 5537,
            "proteasomes": 2215,
            "genes": [
                {
                    "$": "gene",
                    "name": "P1",
                    "activation": [{"from": "P1", "at": 2.0}],
                    "repression": [{"from": "P3", "at": 4.0}]
                },
                {
                    "$": "gene",
                    "name": "P2",
                    "activation": [{"from": "P2", "at": 2.0}],
                    "repression": [{"from": "P1", "at": 4.0}]
                },
                {
                    "$": "gene",
                    "name": "P3",
                    "activation": [{"from": "P3", "at": 2.0}],
                    "repression": [{"from": "P2", "at": 4.0}]
                },
                {
                    "$": "gene",
                    "name": "S1",
                    "activation": [
                        {"from": "S1", "at": 2.0},
                        {"from": "P1", "at": 2.0}
                    ],
                    "repression": [{"from": "S3", "at": 4.0}]
                },
                {
                    "$": "gene",
                    "name": "S2",
                    "activation": [{"from": "S2", "at": 2.0}],
                    "repression": [
                        {"from": "S1", "at": 4.0},
                        {"from": "P1", "at": 4.0}
                    ]
                },
                {
                    "$": "gene",
                    "name": "S3",
                    "activation": [{"from": "S3", "at":2.0}],
                    "repression": [
                        {"from": "S2", "at": 4.0},
                        {"from": "P1", "at": 4.0}
                    ]
                }
            ]
        }}
    }
}
