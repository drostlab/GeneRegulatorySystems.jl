{
    "differentiation": {
        "differentiator": {
            "base_rates": {
                "activation": 2.5,
                "deactivation": 10.0,
                "trigger": 6.6e-7,
                "transcription": 0.015,
                "splicing": 0.02,
                "translation": 2.5e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.0075,
                "protein_decay": 2e-10
            }
        },
        "timer": {
            "base_rates": {
                "activation": 0.1,
                "deactivation": 0.1,
                "trigger": 6.6e-7,
                "transcription": 2.5e7,
                "splicing": 0.02,
                "translation": 1e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.01,
                "protein_decay": 1.0
            }
        },
        "timer_deposit": {"mrnas": 5, "proteins": 30},
        "buffer": [0.002, 0.008],
        "buffer_deposit": 300
    },
    "each": {"start": 3600, "step": 3600, "stop": 3600},
    "as": "time",
    "branch": true,
    "step": {
        "do": {"{regulation/differentiation}": {
            "activation": {"aggregate": "minimum"},
            "repression": {"aggregate": "minimum"},
            "differentiation": {
                "$": "differentiation",
                "timer": {
                    "base_rates": {
                        "$": ["differentiation", "timer", "base_rates"]
                    }
                },
                "differentiator": "trigger",
                "duration": 10000.0,
                "ratio": 0.8,
                "next": {
                    "$": "differentiation",
                    "differentiator": {"$": ["differentiation", "differentiator"], "name": "state0"},
                    "duration": {"$": "time"},
                    "next": {"$": ["differentiation", "differentiator"]},
                    "alternative": {"$": ["differentiation", "differentiator"]}
                },
                "alternative": {
                    "$": "differentiation",
                    "differentiator": {"$": ["differentiation", "differentiator"], "name": "state1"},
                    "duration": {"$": "time"},
                    "next": {"$": ["differentiation", "differentiator"]},
                    "alternative": {"$": ["differentiation", "differentiator"]}
                }
            }
        }},
        "step": [
            {"{add}": {
                "polymerases": 5e5,
                "ribosomes": 2e6,
                "proteasomes": 1e6
            }},
            {"{bootstrap/differentiation}": {"$": "do"}},
            {"each": {"length": 1}, "branch": true, "step":{
                "to": 1000000.0, "step": [
                    1000.0]}}
        ]
    }
}
