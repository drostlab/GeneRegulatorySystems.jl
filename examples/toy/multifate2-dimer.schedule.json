{
    "label": "multifate2-dimer",
    "base_rates": {
        "activation": 0.1,
        "deactivation": 10.0,
        "trigger": 6.6e-7,
        "transcription": 0.001,
        "splicing": 0.02,
        "translation": 2.5e-9,
        "abortion": 0.01,
        "premrna_decay": 0.001,
        "mrna_decay": 0.001,
        "protein_decay": 1e-9
    },
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "name": "A",
                    "base_rates": {
                        "$": "base_rates",
                        "protein_decay": 3.1e-9
                    },
                    "activation": [{"from": "AA", "at": 2.0}]
                },
                {
                    "name": "B",
                    "base_rates": {
                        "$": "base_rates",
                        "protein_decay": 3.1e-9
                    },
                    "activation": [{"from": "BB", "at": 2.0}]
                }
            ],
            "reactions": [
                {"from": ["A", "A"], "rates": [0.02, 0.02], "to": ["AA"]},
                {"from": ["A", "B"], "rates": [0.02, 0.04], "to": ["AB"]},
                {"from": ["B", "B"], "rates": [0.02, 0.02], "to": ["BB"]}
            ]
        }},
        "each": {"start": 50, "step": 25, "stop": 300},
        "as": "x",
        "step": {
            "each": {"start": 50, "step": 25, "stop": 300},
            "as": "y",
            "step": {
                "each": {"length": 20},
                "branch": true,
                "step": [
                    {"{add}": {
                        "polymerases": 5e5,
                        "ribosomes": 2e6,
                        "proteasomes": 1e6,
                        "A.proteins": {"$": "x"},
                        "B.proteins": {"$": "y"},
                        "A.mrnas": 30,
                        "B.mrnas": 30
                    }},
                    {"to": 100000.0, "step": 1000.0}
                ]
            }
        }
    }
}
