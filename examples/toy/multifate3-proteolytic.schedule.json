{
    "label": "multifate3-proteolytic",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.001,
            "splicing": 0.02,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 3e-10
        }
    },
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "$": "gene",
                    "activation": [{"from": 1, "at": 2.0}],
                    "proteolysis": [
                        {"from": 2, "k": 0.001},
                        {"from": 3, "k": 0.001}
                    ]
                },
                {
                    "$": "gene",
                    "activation": [{"from": 2, "at": 2.0}],
                    "proteolysis": [
                        {"from": 1, "k": 0.001},
                        {"from": 3, "k": 0.001}
                    ]
                },
                {
                    "$": "gene",
                    "activation": [{"from": 3, "at": 2.0}],
                    "proteolysis": [
                        {"from": 1, "k": 0.001}, 
                        {"from": 2, "k": 0.001}
                    ]
                }
            ]
        }},
        "each": [150.0, 200.0, 250.0, 300.0],
        "as": "n",
        "step": {
            "each": [150.0, 200.0, 250.0, 300.0],
            "as": "m",
            "step": {
                "branch": true,
                "each": [150.0, 200.0, 250.0, 300.0],
                "as": "p",
                "step": [
                    {"{add}": {
                        "polymerases": 5e5,
                        "ribosomes": 2e6,
                        "proteasomes": 1e6,
                        "1.proteins": {"$": "n"},
                        "2.proteins": {"$": "m"},
                        "3.proteins": {"$": "p"}
                    }},
                    {"to": 10000.0}
                ]
            }
        }
    }
}
