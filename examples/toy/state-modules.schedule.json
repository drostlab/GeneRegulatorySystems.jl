{
    "label": "state-module",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.0015,
            "splicing": 0.02,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 3.0e-10
        }
    },
    "each": [[2e-10, 2e-4]],
    "as": "timer",
    "step":{
        "each": [[0.00010875,9.1250000000000009E-5]],
        "as": "prop",
        "branch": true,
        "step": {
            "do": {"{regulation/v1}": {
                "genes": [
                    
                    {
                        "name": "upstream1",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    {
                        "name": "upstream2",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    
                    {
                        "name": "controller",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "transcription": {"$": ["timer",2]},
                            "protein_decay": {"$": ["timer",1]}
                        },
                        "repression":[{"from":"upstream1", "at": 0.5},
                        {"from":"state1", "at": 2.0},
                        {"from":"state2", "at": 2.0}],
                        "activation":[{"from":"upstream2", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state1", "k": 0.000002},
                            {"from": "state2", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state1",
                        "$": "gene",
                        "activation": [{"from": "state1", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state2", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state2",
                        "$": "gene",
                        "activation": [{"from": "state2", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state1", "k": {"$": ["prop",2]}}
                        ]
                    }
                    
                ],
                "reactions": [
                    {"from": ["controller", "controller"], "rates": [0.002, 0.008], "to": ["controller_buffer"]}
                    ]
                
            }},
            "branch": true,
            "each": [[10, 10],[500, 0],[0, 500]],
            "as": "in",
            "step":{
                "each": {"length": 10},
                "branch": true,
                "step": [
                    {"{add}": {
                        "polymerases": 5e5,
                        "ribosomes": 2e6,
                        "proteasomes": 1e6,
                        "state1.proteins": 100,
                        "state2.proteins": 100,
                        "controller.proteins": 30,
                        "controller_buffer": 500,
                        "controller.mrnas": 5,
                        "upstream1.proteins": {"$": ["in",1]},
                        "upstream2.proteins": {"$": ["in",2]}               
                    }},
                    {"to": 900000.0, "step":5000.0}
                ]
            }
        }
    }
}
