{
    "gene": {
        "base_rates": {
            "activation": 0.05,
            "deactivation": 10.0,
            "trigger": 0.33,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 0.0000009,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 0.000000136
        }
    },
    "in": {
        "model": {
            "kind": "vanilla",
            "polymerases": 50,
            "ribosomes": 5537,
            "proteasomes": 2215,
            "genes": [
                {
                    "$": "gene",
                    "activation": [{"from": 1, "at": 2.0}],
                    "repression": [{"from": 2, "at": 4.0}]
                },
                {
                    "$": "gene",
                    "activation": [{"from": 2, "at": 2.0}],
                    "repression": [{"from": 1, "at": 4.0}]
                }
            ]
        },
        "each": {"start": 0, "step": 25, "stop": 100},
        "as": "a",
        "in": {
            "each": {"start": 0, "step": 25, "stop": 100},
            "as": "b",
            "in": {
                "label": "switch-$a-$b",
                "initial": {
                    "1": {"proteins": {"$": "a"}},
                    "2": {"proteins": {"$": "b"}}
                },
                "each": {"length": 3}
            }
        }
    },
    "take": {"to": 100000.0, "step": 100.0}
}
