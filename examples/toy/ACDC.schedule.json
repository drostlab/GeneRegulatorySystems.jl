[
    {"{set}": {
        "1.proteins": 20,
        "2.proteins": 20,
        "3.proteins": 20
    }},
    {
        "into": "${channel}",
        "gene" : {
            "base_rates": {
                "activation": 0.05,
                "deactivation": 10.0,
                "trigger": 0.33,
                "transcription": 0.001,
                "splicing": 1.0,
                "translation": 0.0000009,
                "abortion": 0.01,
                "premrna_decay": 0.01,
                "mrna_decay": 0.001,
                "protein_decay": 0.000000136
            }
        },
        "each": {"start": 0.0, "length": 5, "stop": 16.0},
        "as": "2->3",
        "step": {
            "branch": true,
            "each": {"start": 0.0, "length": 17, "stop": 16.0},
            "as": "1->3",
            "step": {
                "label": "ACDC-${1->3}-${2->3}",
                "step": 1000.0,
                "to": 200000.0,
                "do": {"{regulation/vanilla}": {
                    "polymerases": 50,
                    "ribosomes": 5537,
                    "proteasomes": 2215,
                    "genes": [
                        {
                            "$": "gene",
                            "activation": [{"from": "1", "at": 2.0}],
                            "repression": [{"from": "3", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "activation": [{"from": "2", "at": 2.0}],
                            "repression": [{"from": "1", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "activation": [{"from": "3", "at": 2.0}],
                            "repression": [
                                {"from": "1", "at": {"$": "1->3"}},
                                {"from": "2", "at": {"$": "2->3"}}
                            ]
                        }
                    ]
                }}
            }
        }
    }
]
