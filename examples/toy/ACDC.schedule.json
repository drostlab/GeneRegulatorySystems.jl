[
    {"{add}": {
        "polymerases": 5e5,
        "ribosomes": 2e6,
        "proteasomes": 1e6,
        "1.proteins": 20,
        "2.proteins": 20,
        "3.proteins": 20
    }},
    {
        "gene" : {
            "base_rates": {
                "activation": 2.5,
                "deactivation": 10.0,
                "trigger": 6.6e-7,
                "transcription": 0.001,
                "splicing": 0.02,
                "translation": 2.5e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.001,
                "protein_decay": 3e-10
            }
        },
        "each": {"start": 0.0, "length": 5, "stop": 16.0},
        "as": "2->3",
        "step": {
            "branch": true,
            "each": {"start": 0.0, "length": 17, "stop": 16.0},
            "as": "1->3",
            "step": {
                "label": "ACDC-${1->3}-${2->3}",
                "step": 1000.0,
                "to": 200000.0,
                "do": {"{regulation/v1}": {
                    "genes": [
                        {
                            "$": "gene",
                            "activation": [{"from": "1", "at": 2.0}],
                            "repression": [{"from": "3", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "activation": [{"from": "2", "at": 2.0}],
                            "repression": [{"from": "1", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "activation": [{"from": "3", "at": 2.0}],
                            "repression": [
                                {"from": "1", "at": {"$": "1->3"}},
                                {"from": "2", "at": {"$": "2->3"}}
                            ]
                        }
                    ]
                }}
            }
        }
    }
]
