{
    "label": "repressilator-entrained",
    "repressilator": {
        "genes": [
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": 1, "at": 2.0}],
                "repression": [{"from": 3, "at": 4.0}]
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": 2, "at": 2.0}],
                "repression": [{"from": 1, "at": 4.0}]
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": 3, "at": 2.0}],
                "repression": [{"from": 2, "at": 4.0}]
            }
        ]
    },
    "step": {
        "do": {"{regulation/v1}": {"$": "repressilator"}},
        "do_with_intervention": {"{regulation/v1}": {
            "$": "repressilator",
            "reactions": [{"from": [2], "rate": 0.0001, "to": []}]
        }},
        "step": [
            {"{add}": {
                "$": ["defaults", "bootstrap"],
                "1.proteins": 100
            }},
            {"to": 450000.0, "step": [
                {"to": 25000.0},
                {"to": 5000.0, "step": {"$":"do_with_intervention"}}
            ]},
            {
                "branch": true,
                "each": {"length": 5},
                "step": {"to": 450000.0, "step": [
                    {"to": 25000.0},
                    {"to": 5000.0, "step": {"$":"do_with_intervention"}}
                ]}
            }
        ]
    }
}
