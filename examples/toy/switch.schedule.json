{
    "anchor": "${channel}",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.001,
            "splicing": 0.02,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.001,
            "mrna_decay": 0.001,
            "protein_decay": 3e-10
        }
    },
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "$": "gene",
                    "activation": [{"from": 1, "at": 2.0}],
                    "repression": [{"from": 2, "at": 4.0}]
                },
                {
                    "$": "gene",
                    "activation": [{"from": 2, "at": 2.0}],
                    "repression": [{"from": 1, "at": 4.0}]
                }
            ]
        }},
        "each": {"start": 0, "step": 25, "stop": 100},
        "as": "a",
        "step": {
            "each": {"start": 0, "step": 25, "stop": 100},
            "as": "b",
            "step": {
                "label": "switch-${a}-${b}",
                "branch": true,
                "each": {"length": 3},
                "step": {
                    "channel": "${anchor}",
                    "step": [
                        {"{add}": {
                            "polymerases": 5e5,
                            "ribosomes": 2e6,
                            "proteasomes": 1e6,
                            "1.proteins": {"$": "a"},
                            "2.proteins": {"$": "b"}
                        }},
                        {"to": 100000.0}
                    ]
                }
            }
        }
    }
}
