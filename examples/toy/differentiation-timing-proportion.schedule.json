{
    "label": "differentiation-timing-proportion",
    "differentiation": {
        "differentiator": {
            "base_rates": {
                "activation": 2.5,
                "deactivation": 10.0,
                "trigger": 6.6e-7,
                "transcription": 0.015,
                "processing": 0.02,
                "translation": 2.5e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.0075,
                "protein_decay": 2e-10
            }
        },
        "timer": {
            "base_rates": {
                "activation": 0.1,
                "deactivation": 0.1,
                "trigger": 6.6e-7,
                "transcription": 2.5e7,
                "processing": 0.02,
                "translation": 1e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.01,
                "protein_decay": 1.0
            }
        },
        "timer_deposit": {"mrnas": 5, "proteins": 30},
        "buffer": [0.002, 0.008],
        "buffer_deposit": 300
    },
    "each": [100000.0, 300000.0],
    "as": "time",
    "branch": true,
    "step": {
        "each": [0.1, 0.5, 0.9],
        "as": "ratio",
        "branch": true,
        "step": {
            "do": {"{regulation/differentiation}": {
                "activation": {"aggregate": "minimum"},
                "repression": {"aggregate": "minimum"},
                "differentiation": {
                    "$": "differentiation",
                    "timer": {
                        "base_rates": {
                            "$": ["differentiation", "timer", "base_rates"]
                        }
                    },
                    "differentiator": "trigger",
                    "duration": {"$": "time"},
                    "ratio": {"$": "ratio"},
                    "next": {"$": ["differentiation", "differentiator"]},
                    "alternative": {"$": ["differentiation", "differentiator"]}
                }
            }},
            "step": [
                {"{add}": {
                    "polymerases": 5e5,
                    "ribosomes": 2e6,
                    "proteasomes": 1e6
                }},
                {"{bootstrap/differentiation}": {"$": "do"}},
                {"each": {"length": 100}, "branch": true, "step": {
                    "to": 500000.0, "step": 1000.0
                }}
            ]
        }
    }
}
