{
    "label": "multifate2-proteolytic",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 3e-10
        }
    },
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "base_rates": {
                        "$": ["gene", "base_rates"],
                        "activation": 0.0
                    }
                },
                {
                    "$": "gene",
                    "activation": [{"from": 2, "at": 2.0}],
                    "proteolysis": [
                        {"from": 1, "k": 0.001},
                        {"from": 3, "k": 0.001}
                    ]
                },
                {
                    "$": "gene",
                    "activation": [{"from": 3, "at": 2.0}],
                    "proteolysis": [
                        {"from": 1, "k": 0.001},
                        {"from": 2, "k": 0.001}
                    ]
                }
            ]
        }},
        "branch": true,
        "each": {"length": 5},
        "step": [
            {"{add}": {
                "polymerases": 5e5,
                "ribosomes": 2e6,
                "proteasomes": 1e6,
                "1.proteins": 100,
                "2.proteins": 100,
                "3.proteins": 100,
                "1.mrnas": 100
            }},
            {"to": 60000.0}
        ]
    }
}
