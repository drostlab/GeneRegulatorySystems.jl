{
    "label": "state-resetting",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.015,
            "processing": 0.02,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.001,
            "mrna_decay": 0.0075,
            "protein_decay": 2.0e-10
        }
    },
    "each": [[2e-10, 1e-2, 5e-10, 2.5e-2, 2e-10, 1e-2]],
    "as": "timer",
    "step":{
        "each": [[0.0001,0.0001]],
        "as": "prop",
        "branch": true,
        "step": {
            "do": {"{regulation/v1}": {
                "genes": [
                    
                    {
                        "name": "upstream1",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    {
                        "name": "upstream2",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    
                    {
                        "name": "controller",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "mrna_decay": 0.01,
                            "translation": 1e-9,
                            "transcription": {"$": ["timer",2]},
                            "protein_decay": {"$": ["timer",1]}
                        },
                        "repression":[{"from":"upstream1", "at": 0.5},
                        {"from":"state1", "at": 2.0},
                        {"from":"state2", "at": 2.0}],
                        "activation":[{"from":"upstream2", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state1", "k": 0.000002},
                            {"from": "state2", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state1",
                        "$": "gene",
                        "activation": [{"from": "state1", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state2", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state2",
                        "$": "gene",
                        "activation": [{"from": "state2", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state1", "k": {"$": ["prop",2]}}
                        ]
                    },

                    {
                        "name": "controller1",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "mrna_decay": 0.01,
                            "translation": 1e-9,
                            "transcription": {"$": ["timer",4]},
                            "protein_decay": {"$": ["timer",3]}
                        },
                        "repression":[{"from":"state1", "at": 0.5},
                        {"from":"state11", "at": 2.0},
                        {"from":"state12", "at": 2.0}],
                        "activation":[{"from":"state2", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state11", "k": 0.000002},
                            {"from": "state12", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state11",
                        "$": "gene",
                        "activation": [{"from": "state11", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller1", "k": 0.0001},
                            {"from": "state12", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state12",
                        "$": "gene",
                        "activation": [{"from": "state12", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller1", "k": 0.0001},
                            {"from": "state11", "k": {"$": ["prop",2]}}
                        ]
                    },

                    {
                        "name": "controller2",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "mrna_decay": 0.01,
                            "translation": 1e-9,
                            "transcription": {"$": ["timer",6]},
                            "protein_decay": {"$": ["timer",5]}
                        },
                        "repression":[{"from":"state2", "at": 0.5},
                        {"from":"state21", "at": 2.0},
                        {"from":"state22", "at": 2.0}],
                        "activation":[{"from":"state1", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state11", "k": 0.000002},
                            {"from": "state12", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state21",
                        "$": "gene",
                        "activation": [{"from": "state21", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller2", "k": 0.0001},
                            {"from": "state22", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state22",
                        "$": "gene",
                        "activation": [{"from": "state22", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller2", "k": 0.0001},
                            {"from": "state21", "k": {"$": ["prop",2]}}
                        ]
                    }
                    
                ],
                "reactions": [
                    {"from": ["controller", "controller"], "rates": [0.002, 0.008], "to": ["controller_buffer"]},
                    {"from": ["controller1", "controller1"], "rates": [0.002, 0.008], "to": ["controller1_buffer"]},
                    {"from": ["controller2", "controller2"], "rates": [0.002, 0.008], "to": ["controller2_buffer"]}
                    ]
                
            }},
            "branch": true,
            "each": [[500, 0]],
            "as": "in",
            "step":{
                "each": {"length": 20},
                "branch": true,
                "step": [
                    {"{add}": {
                        "polymerases": 5e5,
                        "ribosomes": 2e6,
                        "proteasomes": 1e6,
                        "state1.proteins": 100,
                        "state2.proteins": 100,
                        "controller.proteins": 30,
                        "controller_buffer": 500,
                        "controller.mrnas": 5,
                        "state11.proteins": 100,
                        "state12.proteins": 100,
                        "controller1.proteins": 30,
                        "controller1_buffer": 500,
                        "controller1.mrnas": 5,
                        "state21.proteins": 100,
                        "state22.proteins": 100,
                        "controller2.proteins": 30,
                        "controller2_buffer": 500,
                        "controller2.mrnas": 5,
                        "upstream1.proteins": {"$": ["in",1]},
                        "upstream2.proteins": {"$": ["in",2]}               
                    }},
                    {"to": 700000.0, "step":5000.0},
                    {"{add}": {
                        "proteasomes": 1e6
                    }},
                    {"to": 500000.0, "step":5000.0},
                    {"{multiply}": {
                        "proteasomes": 0.5
                    }},
                    {"to": 500000.0, "step":5000.0}
                ]
            }
        }
    }
}
