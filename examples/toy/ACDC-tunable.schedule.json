[
    {"{add}": {
        "polymerases": 5e5,
        "ribosomes": 2e6,
        "proteasomes": 1e6,
        "X.proteins": 150,
        "Y.proteins": 150,
        "Z.proteins": 150,
        "S.proteins": 0
    }},
    {
        "gene" : {
            "base_rates": {
                "activation": 2.5,
                "deactivation": 10.0,
                "trigger": 6.6e-7,
                "transcription": 0.001,
                "splicing": 0.02,
                "translation": 2.5e-9,
                "abortion": 0.01,
                "premrna_decay": 0.001,
                "mrna_decay": 0.001,
                "protein_decay": 2.5e-10
            }
        },
        "branch": true,
        "each": {"length":1},
        "as": "m",
        "step": {
            "branch": true,
            "each": {"length":1},
            "as": "n",
            "step": {
                "do": {"{regulation/v1}": {
                    "activation": {"aggregate": "generalized_mean", "p": 1.0},
                    "genes": [
                        {
                            "$": "gene",
                            "name": "X",
                            "activation": [{"from": "X", "at":  2.0},{"from": "S", "at":  6.0}],
                            "repression": [{"from": "Z", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "name": "Y",
                            "activation": [{"from": "Y", "at":  2.0}],
                            "repression": [{"from": "X", "at": 4.0}]
                        },
                        {
                            "$": "gene",
                            "name": "Z",
                            "activation": [{"from": "Z", "at":  2.0}],
                            "repression": [
                                {"from": "C", "at": 4.0},
                                {"from": "Y", "at": 4.0}
                            ]
                        },
                        {
                            "$": "gene",
                            "name": "S",
                            "base_rates": {
                                "$": ["gene", "base_rates"],
                                "activation": 0.0,
                                "protein_decay": 0.0
                            }
                        }

                    ],
                    "reactions": [
                        {"from": ["S", "X"], "rates": [0.004, 0.002], "to": ["X","C"]}
                    ]
                }},
                "step": [
                {"{add}": {"S.proteins": 0}},
                {"to": 300000.0, "step":5000.0},
                {
                    "to": 200000.0,
                    "step": [
                        {"to": 5000.0, "step": 5000.0},
                        {"{add}": {"S.proteins": 5}}
                    ]
                }, 

                {"to": 500000.0, "step":5000.0},

                {
                    "to": 200000.0,
                    "step": [
                        {"to": 5000.0, "step": 5000.0},
                        {"{add}": {"S.proteins": 7}}
                    ]
                },

                {"to": 500000.0, "step":5000.0},

                {
                    "to": 200000.0,
                    "step": [
                        {"to": 5000.0, "step": 5000.0},
                        {"{multiply}": {"S.proteins": 0.92}}
                    ]
                },
                {"to": 500000.0, "step":5000.0}

                ]
            }
        }
    }
]
