{
    "do": {"{regulation/differentiation}": {
        "differentiation": {
            "$": ["defaults", "differentiation"],
            "differentiator": "differentiator",
            "duration": 50000.0,
            "ratio": 0.8,
            "next": {
                "$": ["defaults", "differentiation"],
                "duration": 25000.0,
                "next": {"$": ["defaults", "differentiation", "differentiator"]},
                "alternative": {"$": ["defaults", "differentiation", "differentiator"]}
            },
            "alternative": {
                "$": ["defaults", "differentiation"],
                "duration": 75000.0,
                "next": {"$": ["defaults", "differentiation", "differentiator"]},
                "alternative": {"$": ["defaults", "differentiation", "differentiator"]}
            }
        }
    }},
    "step": [
        {"{add}": {
            "$": ["defaults", "bootstrap"],
            "differentiator": 500
        }},
        {"{bootstrap/differentiation}": {"$": "do"}},
        {"each": {"length": 100}, "as": "i", "branch": true, "step": {
            "to": 200000.0,
            "step": 1000.0,
            "into": "${into}-replicate-${i}"
        }}
    ]
}
