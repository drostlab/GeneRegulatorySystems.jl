{
    "label": "state-proportion",
    "gene": {
        "base_rates": {
            "activation": 2.5,
            "deactivation": 10.0,
            "trigger": 6.6e-7,
            "transcription": 0.015,
            "processing": 0.02,
            "translation": 2.5e-9,
            "abortion": 0.01,
            "premrna_decay": 0.001,
            "mrna_decay": 0.0075,
            "protein_decay": 2.0e-10
        }
    },
    "each": [[1.0e-10, 2.5e-3]],
    "as": "timer",
    "step":{
        "each": [[0.00010875,9.1250000000000009E-5],[0.00010750000000000001,9.25E-5],[0.00010625000000000001,9.375E-5],[0.000105,9.5E-5],[0.00010375,9.6250000000000009E-5],[0.00010250000000000001,9.75E-5],[0.00010125000000000001,9.875E-5],[0.0001,0.0001],[9.875E-5,0.00010125000000000001],[9.75E-5,0.00010250000000000001],[9.6250000000000009E-5,0.00010375],[9.5E-5,0.000105],[9.375E-5,0.00010625000000000001],[9.25E-5,0.00010750000000000001],[9.1250000000000009E-5,0.00010875]],
        "as": "prop",
        "branch": true,
        "step": {
            "do": {"{regulation/v1}": {
                "genes": [
                    
                    {
                        "name": "upstream1",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    {
                        "name": "upstream2",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.0,
                            "protein_decay": 0.00
                        }
                    },
                    
                    {
                        "name": "controller",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "mrna_decay": 0.01,
                            "translation": 1e-9,
                            "transcription": 5e-3,
                            "protein_decay": 2e-10 
                        },
                        "repression":[{"from":"upstream1", "at": 0.5},
                        {"from":"state1", "at": 2.0},
                        {"from":"state2", "at": 2.0}],
                        "activation":[{"from":"upstream2", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state1", "k": 0.000002},
                            {"from": "state2", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state1",
                        "$": "gene",
                        "activation": [{"from": "state1", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state2", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state2",
                        "$": "gene",
                        "activation": [{"from": "state2", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller", "k": 0.0001},
                            {"from": "state1", "k": {"$": ["prop",2]}}
                        ]
                    },

                    {
                        "name": "controller1",
                        "base_rates": {
                            "$": ["gene", "base_rates"],
                            "activation": 0.1,
                            "deactivation": 0.1,
                            "mrna_decay": 0.01,
                            "translation": 1e-9,
                            "transcription": {"$": ["timer",2]},
                            "protein_decay": {"$": ["timer",1]}
                        },
                        "repression":[{"from":"state1", "at": 0.5},
                        {"from":"state11", "at": 2.0},
                        {"from":"state12", "at": 2.0}],
                        "activation":[{"from":"state2", "at": 0.5}],
                        "proteolysis": [
                            {"from": "state11", "k": 0.000002},
                            {"from": "state12", "k": 0.000002}
                        ]
                    },
                    {
                        "name": "state11",
                        "$": "gene",
                        "activation": [{"from": "state11", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller1", "k": 0.0001},
                            {"from": "state12", "k": {"$": ["prop",1]}}
                        ]
                    },
                    {
                        "name": "state12",
                        "$": "gene",
                        "activation": [{"from": "state12", "at": 2.0}],
                        "proteolysis": [
                            {"from": "controller1", "k": 0.0001},
                            {"from": "state11", "k": {"$": ["prop",2]}}
                        ]
                    }
                ],
                "reactions": [
                    {"from": ["controller", "controller"], "rates": [0.002, 0.008], "to": ["controller_buffer"]},
                    {"from": ["controller1", "controller1"], "rates": [0.002, 0.008], "to": ["controller1_buffer"]}
                    ]
                
            }},
            "branch": true,
            "each": [[500, 0]],
            "as": "in",
            "step":{
                "each": {"length": 100},
                "branch": true,
                "step": [
                    {"{add}": {
                        "polymerases": 5e5,
                        "ribosomes": 2e6,
                        "proteasomes": 1e6,
                        "state1.proteins": 100,
                        "state2.proteins": 100,
                        "controller.proteins": 30,
                        "controller_buffer": 500,
                        "controller.mrnas": 5,
                        "state11.proteins": 100,
                        "state12.proteins": 100,
                        "controller1.proteins": 30,
                        "controller1_buffer": 500,
                        "controller1.mrnas": 5,
                        "upstream1.proteins": {"$": ["in",1]},
                        "upstream2.proteins": {"$": ["in",2]}               
                    }},
                    {"to": 700000.0, "step": 7000.0}
                ]
            }
        }
    }
}
