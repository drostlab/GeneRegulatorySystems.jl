{
    "label": "multifate2-proteolytic-controller-timer",
    
    "each": [2e-10, 4e-10],
    "as": "controller_decay",
    "branch": true,
    "step": {
        "do": {"{regulation/v1}": {
            "genes": [
                {
                    "name": "controller",
                    "base_rates": {
                        "$": ["defaults", "gene", "base_rates"],
                        "activation": 0.0,
                        "protein_decay": {"$": "controller_decay"}
                    }},
                {
                    "name": "A",
                    "base_rates": {
                        "$": ["defaults", "gene", "base_rates"]
                    },
                    "activation": [{"from": "A", "at": 2.0}],
                    "proteolysis": [
                        {"from": "controller", "k": 0.0001},
                        {"from": "B", "k": 0.0001}
                    ]
                },
                {
                    "name": "B",
                    "base_rates": {
                        "$": ["defaults", "gene", "base_rates"]                   
                    },
                    "activation": [{"from": "B", "at": 2.0}],
                    "proteolysis": [
                        {"from": "controller", "k": 0.0001},
                        {"from": "A", "k": 0.0001}
                    ]
                }
            ],
            "reactions": [
                    {"from": ["controller", "controller"], "rates": [0.002, 0.008], "to": ["controller_buffer"]}
                ]
        }},

        "step": {
            "each": {"length":20},
            "branch": true,
            "step": [
                {"{add}": {
                    "$": ["defaults", "bootstrap"],
                    "controller.proteins": 800,
                    "A.proteins": 100,
                    "B.proteins": 100,
                    "A.mrnas": 30,
                    "B.mrnas": 30
                }},
                {"to": 250000.0, "step": 1000.0}
            ]
        }
    }

    
}
