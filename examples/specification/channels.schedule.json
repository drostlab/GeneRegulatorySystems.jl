[
    {"{add}": {
        "polymerases": 5e5,
        "ribosomes": 2e6,
        "proteasomes": 1e6,
        "G1": {"proteins": 100},
        "G2": {"proteins": 200}
    }},
    {
        "anchor": "${into}",
        "into": "{channels}",
        "each": [1.0, 4.0, 13.0],
        "as": "repression_at",
        "step": {
            "branch": true,
            "each": {"length": 3},
            "step": {
                "to": 1000.0,
                "channel": "${anchor}",
                "step": {"{regulation/v1}": {
                    "genes": [
                        {
                            "name": "G1",
                            "base_rates": {
                                "activation": 2.5,
                                "deactivation": 10.0,
                                "trigger": 6.6e-7,
                                "transcription": 0.001,
                                "splicing": 0.02,
                                "translation": 2.5e-9,
                                "abortion": 0.01,
                                "premrna_decay": 0.01,
                                "mrna_decay": 0.001,
                                "protein_decay": 3e-10
                            }
                        },
                        {
                            "name": "G2",
                            "base_rates": {
                                "activation": 2.5,
                                "deactivation": 10.0,
                                "trigger": 6.6e-7,
                                "transcription": 0.001,
                                "splicing": 0.02,
                                "translation": 2.5e-9,
                                "abortion": 0.01,
                                "premrna_decay": 0.01,
                                "mrna_decay": 0.001,
                                "protein_decay": 3e-10
                            },
                            "repression": [{"from": "G1", "at": {"$": "repression_at"}}]
                        }
                    ]
                }}
            }
        }
    }
]
