[
    {"{add}": {
        "$": ["defaults", "bootstrap"],
        "G1": {"proteins": 100},
        "G2": {"proteins": 200}
    }},
    {
        "anchor": "${into}",
        "into": "{channels}",
        "each": [1.0, 4.0, 13.0],
        "as": "repression_at",
        "step": {
            "branch": true,
            "each": {"length": 3},
            "step": {
                "to": 1000.0,
                "channel": "${anchor}",
                "step": {"{regulation/v1}": {
                    "genes": [
                        {
                            "$": ["defaults", "gene"],
                            "name": "G1"
                        },
                        {
                            "$": ["defaults", "gene"],
                            "name": "G2",
                            "repression": [{"from": "G1", "at": {"$": "repression_at"}}]
                        }
                    ]
                }}
            }
        }
    }
]
