{
    "model": {
        "kind": "vanilla",
        "polymerases": 50,
        "ribosomes": 5537,
        "proteasomes": 2215,
        "genes": [
            {
                "base_rates": {
                    "activation": 0.05,
                    "deactivation": 10.0,
                    "trigger": 0.33,
                    "transcription": 0.001,
                    "splicing": 1.0,
                    "translation": 0.0000009,
                    "abortion": 0.01,
                    "premrna_decay": 0.01,
                    "mrna_decay": 0.001,
                    "protein_decay": 0.000000136
                },
                "proteolysis": [{"from": 2, "k": 0.00001}]
            },
            {
                "base_rates": {
                    "activation": 0.05,
                    "deactivation": 10.0,
                    "trigger": 0.33,
                    "transcription": 0.001,
                    "splicing": 1.0,
                    "translation": 0.0000009,
                    "abortion": 0.01,
                    "premrna_decay": 0.01,
                    "mrna_decay": 0.001,
                    "protein_decay": 0.000000136
                },
                "repression": [{"from": 1, "at": 5.0}]
            }
        ]
    },
    "initial": {
        "1": {"proteins": 100},
        "2": {"proteins": 100}
    },
    "take": {"to": 5000.0},
    "in": [
        {
            "channel": "transcriptomic",
            "extract": {"transcriptome-simple": {"collect": 0.8}}
        },
        {
            "channel": "transcriptomic",
            "extract": {
                "transcriptome-amplified": {
                    "collect": 0.9,
                    "cycles": 5,
                    "efficiency": 0.8,
                    "dropout": 0.05,
                    "target": 50
                }
            }
        },
        {
            "channel": "transcriptomic",
            "extract": {
                "Steps": [
                    {"Filter": ".(pre)?mrnas$"},
                    {"ResampleEachBinomial": {"p": 0.9}},
                    {"Repeat": {
                        "count": 5,
                        "step": {
                            "ResampleEachAccumulate": {"ps": [0.05, 0.15, 0.8]}
                        }
                    }},
                    {"ResampleHypergeometric": {"n": 50}}
                ]
            }
        },
        {
            "channel": "multiomic",
            "extract": {
                "transcriptome-amplified": {
                    "collect": 0.9,
                    "cycles": 5,
                    "efficiency": 0.8,
                    "dropout": 0.05,
                    "target": 50
                },
                "proteome-simple": {"collect": 0.7, "target": 100}
            }
        },
        {
            "channel": "multiomic",
            "extract": {
                "Merge": [
                    {"transcriptome-amplified": {
                            "collect": 0.9,
                            "cycles": 5,
                            "efficiency": 0.8,
                            "dropout": 0.05,
                            "target": 50
                    }},
                    {"proteome-simple": {"collect": 0.7, "target": 100}}
                ]
            }
        },
        {
            "channel": "multiomic",
            "extract": {
                "Merge": [
                    {"Steps": [
                        {"Filter": ".(pre)?mrnas$"},
                        {"ResampleEachBinomial": {"p": 0.9}},
                        {"Repeat": {
                            "count": 5,
                            "step": {
                                "ResampleEachAccumulate": {"ps": [0.05, 0.15, 0.8]}
                            }
                        }},
                        {"ResampleHypergeometric": {"n": 50}}
                    ]},
                    {"Steps": [
                        {"Filter": ".proteins$"},
                        {"ResampleEachBinomial": {"p": 0.7}},
                        {"ResampleHypergeometric": {"n": 100}}
                    ]}
                ]
            }
        }
    ]
}
