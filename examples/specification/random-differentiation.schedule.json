                    "$": "typical_base_rates",
                    "activation": 0.1,
                    "deactivation": 0.1,
                    "transcription": 2.5e7,
                    "translation": 1e-9,
                    "mrna_decay": 0.01,
                    "protein_decay": 1.0
                },
                "duration": ["LogNormal", 10.0, 1.0],
                "timer_deposit": {"mrnas": 5, "proteins": 30},
                "buffer": [0.002, 0.008],
                "buffer_deposit": 300
            },
            "peripheral": {
                "base_rates": {"$": "typical_base_rates"},
                "activation": {
                    "adjacency": {
                        "initiator": [
                            [0.8, 0.6],
                            [0.4, 0.2]
                        ],
                        "power": 4,
                        "expected_links_per_gene": 0.3
                    },
                    "at": ["LogNormal", 2.0, 1.0]
                },
                "repression": {
                    "adjacency": {
                        "initiator": [
                            [0.6, 0.5],
                            [0.4, 0.2]
                        ],
                        "power": 4,
                        "expected_links_per_gene": 0.4
                    },
                    "at": ["LogNormal", 2.0, 1.0]
                }
            },
            "activation": {
                "count": ["DiscreteNonParametric", [0, 1, 2], [0.5, 0.4, 0.1]],
                "at": ["LogNormal", 2.0, 1.0]
            },
            "repression": {
                "count": ["DiscreteNonParametric", [0, 1, 2], [0.6, 0.3, 0.1]],
                "at": ["LogNormal", 2.0, 1.0]
            }
        }}
    }
}
