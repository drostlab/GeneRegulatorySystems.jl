{
    "typical_base_rates": {
        "activation": 2.5,
        "deactivation": 10.0,
        "trigger": 6.6e-7,
        "transcription": 0.015,
        "splicing": 0.02,
        "translation": 2.5e-9,
        "abortion": 0.01,
        "premrna_decay": 0.001,
        "mrna_decay": 0.0075,
        "protein_decay": 2e-10
    },
    "step": {
        "step": [
            {"{add}": {"polymerases": 5e5, "ribosomes": 2e6, "proteasomes": 1e6}},
            {"{bootstrap/differentiation}": {"$": "do"}},
            {"to": 100000.0, "step": 100.0}
        ],
        "do": {"{regulation/random-differentiation}": {
            "seed": "differentiation-${seed}",
            "differentiation": {
                "ratios": ["Dirichlet", 6, 5.0],
                "differentiator_base_rates": {"$": "typical_base_rates"},
