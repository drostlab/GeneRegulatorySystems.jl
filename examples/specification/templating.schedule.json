{
    "anchor": {"$": "channel"},
    "typical_gene" : {
        "base_rates": {
            "activation": 0.05,
            "deactivation": 10.0,
            "trigger": 0.33,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 0.0000009,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 0.000000136
        }
    },
    "each": ["default", "Direct", "SortingDirect", "RSSA", "RSSACR"],
    "as": "method",
    "step": {
        "do": {
            "{regulation/vanilla}": {
                "method": {"$": "method"},
                "polymerases": 50,
                "ribosomes": 5537,
                "proteasomes": 2215,
                "genes": [
                    {"$": "typical_gene", "name": "Gene 1"},
                    {
                        "$": "typical_gene",
                        "name": "Gene 2",
                        "repression": [{"from": "Gene 1", "at": 5.0}]
                    }
                ]
            }
        },
        "each": {"start": 150, "step": 10, "stop": 200},
        "as": "proteins",
        "step": {
            "each": [200.0, 1000.0, 5000.0],
            "as": "t",
            "step": {
                "label": "${method}-p${proteins}-at${t}",
                "channel": "${anchor}",
                "branch": true,
                "each": {"length": 3},
                "step": [
                    {"{set}": {
                        "Gene 1": {"proteins": {"$": "proteins"}},
                        "Gene 2": {"proteins": {"$": "proteins"}}
                    }},
                    {"$": "t"},
                    {"{extract-transcriptome-amplified}": {
                        "cycles": 3,
                        "target": 200
                    }}
                ]
            }
        }
    }
}
