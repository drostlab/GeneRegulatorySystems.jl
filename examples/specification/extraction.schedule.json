[
    {"{set}": {
        "polymerases": 500000,
        "ribosomes": 5537,
        "proteasomes": 2215,
        "1": {"proteins": 100},
        "2": {"proteins": 100}
    }},
    {
        "to": 5000.0,
        "step": {"{regulation/vanilla}": {
            "genes": [
                {
                    "base_rates": {
                        "activation": 2.5,
                        "deactivation": 10.0,
                        "trigger": 0.00000066,
                        "transcription": 0.001,
                        "splicing": 1.0,
                        "translation": 0.0000009,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 0.000000136
                    },
                    "proteolysis": [{"from": 2, "k": 0.00001}]
                },
                {
                    "base_rates": {
                        "activation": 2.5,
                        "deactivation": 10.0,
                        "trigger": 0.00000066,
                        "transcription": 0.001,
                        "splicing": 1.0,
                        "translation": 0.0000009,
                        "abortion": 0.01,
                        "premrna_decay": 0.01,
                        "mrna_decay": 0.001,
                        "protein_decay": 0.000000136
                    },
                    "repression": [{"from": 1, "at": 5.0}]
                }
            ]
        }}
    },
    {
        "into": "${into}-transcriptomic",
        "branch": true,
        "step": [
            {"{extract-transcriptome-simple}": {"collect": 0.8}},
            {"{extract-transcriptome-amplified}": {
                "collect": 0.9,
                "cycles": 5,
                "efficiency": 0.8,
                "dropout": 0.05,
                "target": 50
            }},
            {
                "#": "The above {extract-transcriptome-amplified} is equivalent to this schedule.",
                "channel'": {"$": "channel"},
                "into'": {"$": "into"},
                "into": null,
                "step": [
                    {"{filter}": ".(pre)?mrnas$"},
                    {"{resample-each-binomial}": 0.9},
                    {"each": {"length": 5}, "step": {
                        "{resample-each-accumulate}": [0.05, 0.15, 0.8]}
                    },
                    {"{resample-hypergeometric}": 50},
                    {"channel": {"$": "channel'"}, "into": {"$": "into'"}, "step": {}}
                ]
            }
        ]
    },
    {
        "into": "{channels}",
        "channel": "${into}-multiomic",
        "step": [
            {"branch": true, "step": [
                {"{extract-transcriptome-amplified}": {
                    "collect": 0.9,
                    "cycles": 5,
                    "efficiency": 0.8,
                    "dropout": 0.05,
                    "target": 50
                }},
                {"{extract-proteome-simple}": {"collect": 0.7, "target": 100}}
            ]},
            {"{merge}": "+"}
        ]
    }
]
