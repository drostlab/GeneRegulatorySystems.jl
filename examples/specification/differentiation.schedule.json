                "ratio": 0.8,
                "next": {
                    "$": "differentiation",
                    "differentiator": {"$": ["differentiation", "differentiator"], "name": "specialized"},
                    "duration": 15000.0,
                    "next": {"$": ["differentiation", "differentiator"], "name": "specialized_A"},
                    "alternative": "specialized_B"
                },
                "alternative": {"$": ["differentiation", "differentiator"], "name": "other"}
            },
            "genes": [
                {
                    "name": "regulated_by_A",
                    "base_rates": {
                        "activation": 2.5,
                        "deactivation": 10.0,
                        "trigger": 6.6e-7,
                        "transcription": 0.015,
                        "splicing": 0.02,
                        "translation": 2.5e-9,
                        "abortion": 0.01,
                        "premrna_decay": 0.001,
                        "mrna_decay": 0.0075,
                        "protein_decay": 2e-10
                    },
                    "activation": [{"from": "specialized_A", "at": 5.0}]
                },
                {
                    "$": ["differentiation", "differentiator"],
                    "name": "specialized_B"
                }
            ]
        }}
    }
