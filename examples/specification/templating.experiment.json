{
    "typical_gene" : {
        "base_rates": {
            "activation": 0.05,
            "deactivation": 10.0,
            "trigger": 0.33,
            "transcription": 0.001,
            "splicing": 1.0,
            "translation": 0.0000009,
            "abortion": 0.01,
            "premrna_decay": 0.01,
            "mrna_decay": 0.001,
            "protein_decay": 0.000000136
        }
    },
    "each": [
        {"kind": "vanilla", "method": "default"},
        {"kind": "vanilla", "method": "Direct"},
        {"kind": "vanilla", "method": "SortingDirect"},
        {"kind": "vanilla", "method": "RSSA"},
        {"kind": "vanilla", "method": "RSSACR"}
    ],
    "as": "variant",
    "in": {
        "model": {
            "$": "variant",
            "polymerases": 50,
            "ribosomes": 5537,
            "proteasomes": 2215,
            "genes": [
                {"$": "typical_gene", "name": "Gene 1"},
                {
                    "$": "typical_gene",
                    "name": "Gene 2",
                    "repression": [{"from": "Gene 1", "at": 5.0}]
                }
            ]
        },
        "kind": {"$": ["variant", "kind"]},
        "method": {"$": ["variant", "method"]},
        "each": {"start": 150, "step": 10, "stop": 200},
        "as": "proteins",
        "in": {
            "initial": {
                "Gene 1": {"proteins": {"$": "proteins"}},
                "Gene 2": {"proteins": {"$": "proteins"}}
            },
            "each": [200.0, 1000.0, 5000.0],
            "as": "t",
            "in": {
                "take": {"$": "t"},
                "label": "$kind-$method-p$proteins-at$t",
                "each": {"length": 3}
            }
        }
    },
    "extract": {
        "transcriptome-amplified": {
            "cycles": 10,
            "target": 200
        }
    }
}
