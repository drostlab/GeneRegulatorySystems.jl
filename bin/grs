#!/bin/sh
BIN=$(dirname $0)
COMMAND=$1

# Check if `]instantiate` needs to be run for the current `bin/Manifest.toml`.
# If so, run it and take note of the instantiated state (unless `bin` is
# write-protected, which is not really a problem since `]instantiate` is
# idempotent, though it will add latency).
if ! cmp --silent "$BIN/Manifest.toml" "$BIN/Instantiated.toml"; then
    julia --project="$BIN" -e'import Pkg; Pkg.instantiate(verbose = true)' && \
        cp "$BIN/Manifest.toml" "$BIN/Instantiated.toml" 2>/dev/null
fi

if [ -z "$COMMAND" ]; then
    echo "usage: $0 <command> [args...]"
    echo
    echo "commands:"
    for SCRIPT in $(cd "$BIN"; echo *.jl); do
        echo "  ${SCRIPT%.*}"
    done
    exit 0
fi

shift

if [ "$COMMAND" = "sysimage" ]; then
    # We special-case the `sysimage` command to itself always use the default
    # sysimage to avoid trouble in case of broken or stale sysimages, e.g.
    # when recompiling. But we still would like it to be as fast as possible,
    # so to reduce latency in the non-compiling branches, we tell Julia to
    # reduce compilation. This especially applies to `sysimage invocation`,
    # which gets called for all other commands to resolve the sysimage
    # to use.
    # However, since `sysimage compile` is a longer-running operation, we
    # specifically exclude it from reduced Julia compilation.
    case "$@" in
        *compile*) exec julia --project="$BIN" "$BIN/sysimage.jl" "$@";;
        *) exec julia --project="$BIN" --compile=min "$BIN/sysimage.jl" "$@";;
    esac
fi

eval exec $($0 sysimage invocation) "$BIN/$COMMAND.jl" "$@"
